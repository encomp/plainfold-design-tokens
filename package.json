{
  "name": "@plainfold/design-tokens",
  "version": "0.1.0",
  "description": "Theme token contract, validation, and library management for Plainfold apps",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./tokens.css": "./src/tokens.css"
  },
  "files": ["dist", "src/tokens.css"],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@plainfold/store": "github:encomp/plainfold-store",
    "dompurify": "^3.0.0"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "zod": ">=3.24.0"
  },
  "devDependencies": {
    "@plainfold/dev-config": "github:encomp/plainfold-dev-config",
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/dom": "^10.4.0",
    "@types/dompurify": "^3.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "dexie": "^4.0.0",
    "eslint": "^10.0.0",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0",
    "zod": "^3.24.0"
  },
  "license": "MIT"
}
